<odoo>
    <record id="view_pharmacie_reappro_auto_wizard_form" model="ir.ui.view">
        <field name="name">pharmacie.reappro.auto.wizard.form</field>
        <field name="model">pharmacie.reappro.auto.wizard</field>
        <field name="arch" type="xml">
            <form>
                <p>
                    Médicaments dont le stock actuel est inférieur ou égal au seuil
                    d'alerte. Ajustez les quantités si nécessaire avant de valider.
                </p>
                <field name="ligne_ids">
                    <list editable="bottom">
                        <field name="medicament_id" readonly="1"/>
                        <field name="fournisseur_id"/>
                        <field name="quantite_suggeree"/>
                    </list>
                </field>
                <footer>
                    <button string="Valider" name="action_valider" type="object"
                            class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pharmacie_reappro_auto_wizard" model="ir.actions.act_window">
        <field name="name">Réapprovisionnement automatique</field>
        <field name="res_model">pharmacie.reappro.auto.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
