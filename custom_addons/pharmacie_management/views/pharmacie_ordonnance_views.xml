<odoo>
    <record id="view_pharmacie_ordonnance_form" model="ir.ui.view">
        <field name="name">pharmacie.ordonnance.form</field>
        <field name="model">pharmacie.ordonnance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Patient">
                            <field name="patient_nom"/>
                            <field name="patient_age"/>
                            <field name="patient_genre"/>
                        </group>
                        <group string="Prescription">
                            <field name="medecin_nom"/>
                            <field name="structure_sante"/>
                            <field name="date_prescription"/>
                            <field name="statut"/>
                            <field name="vente_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Médicaments prescrits">
                        <field name="medicament_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Scan de l'ordonnance">
                        <field name="scan_ordonnance" widget="image" class="oe_avatar"/>
                    </group>
                    <notebook>
                        <page string="Posologie" name="posologie">
                            <field name="posologie_ids">
                                <list editable="bottom">
                                    <field name="medicament_id"/>
                                    <field name="instructions"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pharmacie_ordonnance_list" model="ir.ui.view">
        <field name="name">pharmacie.ordonnance.list</field>
        <field name="model">pharmacie.ordonnance</field>
        <field name="arch" type="xml">
            <list default_order="date_prescription desc">
                <field name="patient_nom"/>
                <field name="medecin_nom"/>
                <field name="date_prescription"/>
                <field name="statut"/>
                <field name="vente_id"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacie_ordonnance_search" model="ir.ui.view">
        <field name="name">pharmacie.ordonnance.search</field>
        <field name="model">pharmacie.ordonnance</field>
        <field name="arch" type="xml">
            <search>
                <field name="patient_nom"/>
                <field name="medecin_nom"/>
                <filter name="en_attente" string="En attente"
                        domain="[('statut', '=', 'en_attente')]"/>
                <filter name="delivree_complete" string="Délivrée complètement"
                        domain="[('statut', '=', 'delivree_complete')]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_statut" string="Statut"
                            context="{'group_by': 'statut'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pharmacie_ordonnance" model="ir.actions.act_window">
        <field name="name">Ordonnances</field>
        <field name="res_model">pharmacie.ordonnance</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
