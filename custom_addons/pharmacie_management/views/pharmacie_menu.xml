<odoo>
    <menuitem id="menu_pharmacie_root" name="Pharmacie" sequence="10"/>

    <!-- Caisse : accessible à tous les profils -->
    <menuitem id="menu_pharmacie_caisse" name="Caisse"
              parent="menu_pharmacie_root" sequence="10"/>
    <menuitem id="menu_pharmacie_vente_nouvelle" name="Nouvelle vente"
              parent="menu_pharmacie_caisse" action="action_pharmacie_vente_nouvelle"
              sequence="10"/>
    <menuitem id="menu_pharmacie_vente_historique" name="Historique des ventes"
              parent="menu_pharmacie_caisse" action="action_pharmacie_vente"
              sequence="20"/>

    <!-- Ordonnances : accessible à tous les profils -->
    <menuitem id="menu_pharmacie_ordonnances" name="Ordonnances"
              parent="menu_pharmacie_root" sequence="20"/>
    <menuitem id="menu_pharmacie_ordonnance_liste" name="Liste des ordonnances"
              parent="menu_pharmacie_ordonnances" action="action_pharmacie_ordonnance"
              sequence="10"/>

    <!-- Configuration : Pharmacien et Gestionnaire uniquement -->
    <menuitem id="menu_pharmacie_configuration" name="Configuration"
              parent="menu_pharmacie_root" sequence="90"
              groups="group_pharmacie_pharmacien"/>

    <record id="action_pharmacie_categorie" model="ir.actions.act_window">
        <field name="name">Catégories de médicaments</field>
        <field name="res_model">pharmacie.categorie</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_pharmacie_categorie" name="Catégories de médicaments"
              parent="menu_pharmacie_configuration" action="action_pharmacie_categorie"
              sequence="10"/>

    <record id="action_pharmacie_parametres" model="ir.actions.act_window">
        <field name="name">Paramètres de la pharmacie</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_pharmacie_parametres" name="Paramètres de la pharmacie"
              parent="menu_pharmacie_configuration" action="action_pharmacie_parametres"
              sequence="20"/>

    <!-- Stock : accessible à tous les profils (lecture seule pour le vendeur via l'ACL) -->
    <menuitem id="menu_pharmacie_stock" name="Stock"
              parent="menu_pharmacie_root" sequence="30"/>
    <menuitem id="menu_pharmacie_medicament" name="Médicaments"
              parent="menu_pharmacie_stock" action="action_pharmacie_medicament"
              sequence="10"/>
    <menuitem id="menu_pharmacie_lot" name="Lots et stocks"
              parent="menu_pharmacie_stock" action="action_pharmacie_lot"
              sequence="20"/>

    <record id="action_pharmacie_lot_alertes" model="ir.actions.act_window">
        <field name="name">Alertes de péremption / rupture</field>
        <field name="res_model">pharmacie.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">['|', ('statut', 'in', ['expire', 'epuise']), ('date_peremption', '&lt;=', (context_today() + relativedelta(days=30)).strftime('%Y-%m-%d'))]</field>
    </record>
    <menuitem id="menu_pharmacie_alertes" name="Alertes de péremption / rupture"
              parent="menu_pharmacie_stock" action="action_pharmacie_lot_alertes"
              sequence="30"/>

    <!-- Fournisseurs : Pharmacien et Gestionnaire uniquement -->
    <menuitem id="menu_pharmacie_fournisseurs" name="Fournisseurs"
              parent="menu_pharmacie_root" sequence="40"
              groups="group_pharmacie_pharmacien"/>

    <record id="action_pharmacie_fournisseur" model="ir.actions.act_window">
        <field name="name">Fournisseurs</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_fournisseur_pharma', '=', True)]</field>
        <field name="context">{'default_is_fournisseur_pharma': True}</field>
    </record>
    <menuitem id="menu_pharmacie_fournisseur_liste" name="Liste des fournisseurs"
              parent="menu_pharmacie_fournisseurs" action="action_pharmacie_fournisseur"
              sequence="10"/>

    <record id="action_pharmacie_reappro" model="ir.actions.act_window">
        <field name="name">Réapprovisionnements</field>
        <field name="res_model">pharmacie.reappro</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_pharmacie_reappro" name="Réapprovisionnements"
              parent="menu_pharmacie_fournisseurs" action="action_pharmacie_reappro"
              sequence="20"/>

    <!-- Rapports : Pharmacien et Gestionnaire uniquement.
         Le wizard "Bilan de caisse" (ticket #45) ajoutera l'entrée
         "Bilan de caisse" sous ce menu. -->
    <menuitem id="menu_pharmacie_rapports" name="Rapports"
              parent="menu_pharmacie_root" sequence="50"
              groups="group_pharmacie_pharmacien"/>
</odoo>
