<odoo>
    <record id="view_pharmacie_vente_form" model="ir.ui.view">
        <field name="name">pharmacie.vente.form</field>
        <field name="model">pharmacie.vente</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirmer" string="Confirmer" type="object"
                            class="btn-primary" invisible="statut != 'brouillon'"/>
                    <button name="action_annuler" string="Annuler" type="object"
                            invisible="statut == 'annulee'"/>
                    <field name="statut" widget="statusbar"
                           statusbar_visible="brouillon,confirmee"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="reference"/>
                            <field name="client_id"/>
                            <field name="vendeur_id"/>
                            <field name="ordonnance_id"/>
                        </group>
                        <group>
                            <field name="date_vente" readonly="1"/>
                            <field name="mode_paiement"/>
                            <field name="montant_ht"/>
                            <field name="tva"/>
                            <field name="montant_ttc"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lignes de vente" name="lignes">
                            <field name="ligne_ids">
                                <list editable="bottom">
                                    <field name="medicament_id"/>
                                    <field name="quantite"/>
                                    <field name="prix_unitaire"/>
                                    <field name="lot_id" readonly="1"/>
                                    <field name="montant_ht"/>
                                    <field name="montant_tva"/>
                                    <field name="montant_ttc"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pharmacie_vente_list" model="ir.ui.view">
        <field name="name">pharmacie.vente.list</field>
        <field name="model">pharmacie.vente</field>
        <field name="arch" type="xml">
            <list decoration-muted="statut == 'annulee'" default_order="date_vente desc">
                <field name="reference"/>
                <field name="date_vente"/>
                <field name="client_id"/>
                <field name="vendeur_id"/>
                <field name="mode_paiement"/>
                <field name="montant_ttc"/>
                <field name="statut"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacie_vente_search" model="ir.ui.view">
        <field name="name">pharmacie.vente.search</field>
        <field name="model">pharmacie.vente</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="client_id"/>
                <field name="vendeur_id"/>
                <filter name="brouillon" string="Brouillon" domain="[('statut', '=', 'brouillon')]"/>
                <filter name="confirmee" string="Confirmée" domain="[('statut', '=', 'confirmee')]"/>
                <filter name="annulee" string="Annulée" domain="[('statut', '=', 'annulee')]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_vendeur" string="Vendeur"
                            context="{'group_by': 'vendeur_id'}"/>
                    <filter name="group_statut" string="Statut"
                            context="{'group_by': 'statut'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pharmacie_vente" model="ir.actions.act_window">
        <field name="name">Historique des ventes</field>
        <field name="res_model">pharmacie.vente</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_pharmacie_vente_nouvelle" model="ir.actions.act_window">
        <field name="name">Nouvelle vente</field>
        <field name="res_model">pharmacie.vente</field>
        <field name="view_mode">form,list</field>
    </record>
</odoo>
