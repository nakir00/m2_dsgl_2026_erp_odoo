<odoo>
    <record id="view_pharmacie_lot_list" model="ir.ui.view">
        <field name="name">pharmacie.lot.list</field>
        <field name="model">pharmacie.lot</field>
        <field name="arch" type="xml">
            <list decoration-danger="jours_avant_peremption &lt; 30"
                  decoration-muted="statut in ('expire', 'epuise')"
                  default_order="date_peremption">
                <field name="numero_lot"/>
                <field name="medicament_id"/>
                <field name="date_fabrication"/>
                <field name="date_peremption"/>
                <field name="jours_avant_peremption"/>
                <field name="quantite_initiale"/>
                <field name="quantite_restante"/>
                <field name="statut"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacie_lot_form" model="ir.ui.view">
        <field name="name">pharmacie.lot.form</field>
        <field name="model">pharmacie.lot</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="numero_lot" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="medicament_id"/>
                            <field name="reappro_id" readonly="1"/>
                            <field name="statut"/>
                        </group>
                        <group>
                            <field name="date_fabrication"/>
                            <field name="date_peremption"/>
                            <field name="jours_avant_peremption"/>
                        </group>
                    </group>
                    <group>
                        <group string="Quantités">
                            <field name="quantite_initiale"/>
                            <field name="quantite_restante"/>
                        </group>
                        <group string="Prix">
                            <field name="prix_achat_lot"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pharmacie_lot_search" model="ir.ui.view">
        <field name="name">pharmacie.lot.search</field>
        <field name="model">pharmacie.lot</field>
        <field name="arch" type="xml">
            <search>
                <field name="numero_lot"/>
                <field name="medicament_id"/>
                <filter name="valide" string="Valide" domain="[('statut', '=', 'valide')]"/>
                <filter name="expire" string="Expiré" domain="[('statut', '=', 'expire')]"/>
                <filter name="epuise" string="Épuisé" domain="[('statut', '=', 'epuise')]"/>
                <filter name="peremption_proche" string="Péremption proche (&lt; 30 jours)"
                        domain="[('date_peremption', '&lt;=', (context_today() + relativedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_medicament" string="Médicament"
                            context="{'group_by': 'medicament_id'}"/>
                    <filter name="group_statut" string="Statut"
                            context="{'group_by': 'statut'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pharmacie_lot" model="ir.actions.act_window">
        <field name="name">Lots et stocks</field>
        <field name="res_model">pharmacie.lot</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
